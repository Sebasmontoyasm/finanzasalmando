# AWS S3 Configuration
# Copia este archivo a .env.local y actualiza con tus valores

# Nombre del bucket S3 (debe ser único globalmente)
NEXT_PUBLIC_S3_BUCKET_NAME=finanzasalmando.com

# Región de AWS
NEXT_PUBLIC_S3_REGION=us-east-1

# URL completa del bucket (se construye automáticamente)
# https://{BUCKET_NAME}.s3.{REGION}.amazonaws.com
NEXT_PUBLIC_S3_BUCKET_URL=https://finanzasalmando.com

# Opcional: CloudFront distribution URL (si usas CDN)
# NEXT_PUBLIC_CLOUDFRONT_URL=https://d123456.cloudfront.net
